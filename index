let filtered=[...contacts];
let page=0;
const pageSize=15;

function filterTable(){
  const q=document.getElementById('searchInput').value.toLowerCase();
  const ev=document.getElementById('filterEvento').value;
  const multi=document.getElementById('filterMulti').value;
  filtered=contacts.filter(r=>{
    const match=!q||(r.n+' '+r.a+' '+r.emp+' '+r.e).toLowerCase().includes(q);
    const matchEv=!ev||r.ev.includes(ev);
    const matchMulti=!multi||(multi==='multi'&&r.cnt>1);
    return match&&matchEv&&matchMulti;
  });
  page=0;
  renderTable();
}

function renderTable(){
  const tbody=document.getElementById('tableBody');
  const start=page*pageSize;
  const slice=filtered.slice(start,start+pageSize);
  tbody.innerHTML=slice.map(r=>`<tr>
    <td>${r.n||'—'}</td><td>${r.a||'—'}</td>
    <td style="color:var(--purple)">${r.e||'—'}</td>
    <td>${r.t||'—'}</td><td>${r.emp||'—'}</td>
    <td>${r.c||'—'}</td><td>${r.city||'—'}</td>
    <td>${r.ev.split(' | ').map(e=>`<span class="tag-evento${r.cnt>1?' multi':''}">${e}</span>`).join('')}</td>
  </tr>`).join('');
  document.getElementById('tableCount').textContent=`Mostrando ${start+1}–${Math.min(start+pageSize,filtered.length)} de ${filtered.length} contactos`;
  document.getElementById('pageInfo').textContent=`Pág. ${page+1} / ${Math.ceil(filtered.length/pageSize)||1}`;
  document.getElementById('btnPrev').disabled=page===0;
  document.getElementById('btnNext').disabled=start+pageSize>=filtered.length;
}

function changePage(dir){page+=dir;renderTable();}

