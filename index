<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MGN Eventos — Dashboard Unificado</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#f5f4f0;--surface:#fff;--border:#d3d1c7;
  --t1:#2c2c2a;--t2:#5f5e5a;--t3:#888780;
  --green:#0f6e56;--green-lt:#e1f5ee;
  --purple:#3c3489;--purple-lt:#eeedfe;
  --amber:#ba7517;--amber-lt:#faeeda;
  --red:#a32d2d;--red-lt:#fcebeb;
  --gray-lt:#f1efe8;--r-md:8px;--r-lg:12px;
}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Arial,sans-serif;background:var(--bg);color:var(--t1);padding:0}
.page{max-width:1100px;margin:0 auto;padding:24px 20px 48px}
.page-title{font-size:20px;font-weight:700;color:var(--t1)}
.page-sub{font-size:12px;color:var(--t3);margin-top:3px;margin-bottom:20px}
.tabs{display:flex;gap:4px;background:var(--surface);border:0.5px solid var(--border);border-radius:var(--r-lg);padding:4px;width:fit-content;margin-bottom:20px;flex-wrap:wrap}
.tab{font-size:12px;font-weight:500;padding:6px 14px;border-radius:var(--r-md);cursor:pointer;color:var(--t2);border:none;background:transparent;transition:all .15s}
.tab.active{background:var(--t1);color:#fff}
.tab:hover:not(.active){background:var(--gray-lt)}
.panel{display:none}
.panel.active{display:block}
.metrics-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:10px;margin-bottom:16px}
.metric{background:var(--surface);border:0.5px solid var(--border);border-radius:var(--r-md);padding:12px 14px}
.metric-val{font-size:24px;font-weight:700;line-height:1.1}
.metric-lbl{font-size:11px;color:var(--t3);margin-top:3px;line-height:1.4}
.card{background:var(--surface);border:0.5px solid var(--border);border-radius:var(--r-lg);padding:16px 18px;margin-bottom:12px}
.card-title{font-size:13px;font-weight:600;margin-bottom:12px}
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px}
.three-col{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:12px}
.bar-row{display:flex;align-items:center;gap:8px;font-size:12px;margin-bottom:6px}
.bar-label{min-width:200px;color:var(--t2)}
.bar-wrap{flex:1;background:var(--gray-lt);border-radius:4px;height:8px;overflow:hidden}
.bar-fill{height:100%;border-radius:4px}
.bar-val{font-weight:600;min-width:38px;text-align:right;font-size:12px}
.tbl-row{display:flex;justify-content:space-between;align-items:center;padding:5px 0;border-bottom:0.5px solid var(--gray-lt);font-size:12px}
.tbl-row:last-child{border:none}
.pill{font-size:11px;padding:2px 9px;border-radius:10px;font-weight:500;white-space:nowrap}
.chart-wrap{position:relative;width:100%}
.legend{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:10px}
.legend-item{display:flex;align-items:center;gap:5px;font-size:11px;color:var(--t2)}
.legend-dot{width:10px;height:10px;border-radius:2px;flex-shrink:0}
.search-wrap{display:flex;gap:8px;margin-bottom:12px;flex-wrap:wrap}
.search-wrap input,.search-wrap select{font-size:12px;padding:7px 10px;border:0.5px solid var(--border);border-radius:var(--r-md);background:var(--surface);color:var(--t1);min-width:160px}
.search-wrap input:focus,.search-wrap select:focus{outline:none;border-color:var(--purple)}
.data-table{width:100%;border-collapse:collapse;font-size:12px}
.data-table th{background:var(--purple-lt);color:var(--purple);font-weight:600;padding:8px 10px;text-align:left;border-bottom:0.5px solid var(--border);font-size:11px;white-space:nowrap}
.data-table td{padding:7px 10px;border-bottom:0.5px solid var(--gray-lt);color:var(--t2);vertical-align:top}
.data-table tr:hover td{background:var(--purple-lt)}
.data-table tr:last-child td{border:none}
.tag-evento{display:inline-block;font-size:10px;padding:1px 6px;border-radius:8px;background:var(--purple-lt);color:var(--purple);margin:1px;white-space:nowrap}
.tag-evento.multi{background:var(--amber-lt);color:var(--amber)}
.pagination{display:flex;align-items:center;gap:8px;margin-top:10px;font-size:12px;color:var(--t3)}
.pagination button{font-size:11px;padding:4px 10px;border:0.5px solid var(--border);border-radius:var(--r-md);background:var(--surface);cursor:pointer;color:var(--t1)}
.pagination button:hover{background:var(--gray-lt)}
.pagination button:disabled{opacity:0.4;cursor:default}
.alert{border-left:3px solid;border-radius:0 var(--r-md) var(--r-md) 0;padding:9px 12px;font-size:11px;margin-top:10px;line-height:1.5}
.footer{margin-top:24px;font-size:11px;color:var(--t3);text-align:center}
@media(max-width:700px){.metrics-grid{grid-template-columns:1fr 1fr}.two-col,.three-col{grid-template-columns:1fr}.bar-label{min-width:120px}}
</style>
</head>
<body>
<div class="page">
  <div class="page-title">Dashboard Eventos MGN — Base Unificada</div>
  <div class="page-sub">11 fuentes de datos · 2024–2025 · Enlazar.digital</div>

  <div class="tabs">
    <button class="tab active" onclick="showPanel('resumen',this)">Resumen</button>
    <button class="tab" onclick="showPanel('eventos',this)">Eventos</button>
    <button class="tab" onclick="showPanel('empresas',this)">Empresas</button>
    <button class="tab" onclick="showPanel('contactos',this)">Contactos</button>
    <button class="tab" onclick="showPanel('sustent',this)">Sustentabilidad</button>
  </div>

  <!-- ══════════ PANEL RESUMEN ══════════ -->
  <div id="panel-resumen" class="panel active">
    <div class="metrics-grid">
      <div class="metric"><div class="metric-val">1.037</div><div class="metric-lbl">Contactos únicos<br>deduplicados</div></div>
      <div class="metric"><div class="metric-val" style="color:var(--red)">132</div><div class="metric-lbl">Duplicados<br>eliminados</div></div>
      <div class="metric"><div class="metric-val" style="color:var(--purple)">108</div><div class="metric-lbl">Asistieron a<br>2+ eventos</div></div>
      <div class="metric"><div class="metric-val" style="color:var(--green)">9</div><div class="metric-lbl">Eventos<br>unificados</div></div>
      <div class="metric"><div class="metric-val">302</div><div class="metric-lbl">Respuestas de<br>sustentabilidad</div></div>
    </div>

    <div class="two-col">
      <div class="card">
        <div class="card-title">Completitud de la base unificada</div>
        <div class="bar-row"><span class="bar-label">Con email válido</span><div class="bar-wrap"><div class="bar-fill" style="width:84.2%;background:#0f6e56"></div></div><span class="bar-val">873</span></div>
        <div class="bar-row"><span class="bar-label">Con teléfono</span><div class="bar-wrap"><div class="bar-fill" style="width:85.1%;background:#0f6e56"></div></div><span class="bar-val">882</span></div>
        <div class="bar-row"><span class="bar-label">Con empresa</span><div class="bar-wrap"><div class="bar-fill" style="width:88.8%;background:#3c3489"></div></div><span class="bar-val">921</span></div>
        <div class="bar-row"><span class="bar-label">Con cargo / puesto</span><div class="bar-wrap"><div class="bar-fill" style="width:43.7%;background:#ba7517"></div></div><span class="bar-val">453</span></div>
        <div class="bar-row" style="margin-bottom:0"><span class="bar-label">Con respuesta sustentabilidad</span><div class="bar-wrap"><div class="bar-fill" style="width:29.1%;background:#888780"></div></div><span class="bar-val">302</span></div>
      </div>
      <div class="card">
        <div class="card-title">Registros por evento</div>
        <div class="chart-wrap" style="height:220px"><canvas id="chartEventos"></canvas></div>
      </div>
    </div>

    <div class="two-col">
      <div class="card">
        <div class="card-title">Top ciudades</div>
        <div class="tbl-row"><span>San Nicolás</span><span class="pill" style="background:var(--purple-lt);color:var(--purple)">272</span></div>
        <div class="tbl-row"><span>Rosario</span><span class="pill" style="background:var(--green-lt);color:#085041">197</span></div>
        <div class="tbl-row"><span>La Plata</span><span class="pill" style="background:var(--green-lt);color:#085041">67</span></div>
        <div class="tbl-row"><span>Campana</span><span class="pill" style="background:var(--green-lt);color:#085041">52</span></div>
        <div class="tbl-row"><span>Villa Constitución</span><span class="pill" style="background:var(--amber-lt);color:#633806">42</span></div>
        <div class="tbl-row"><span>San Lorenzo</span><span class="pill" style="background:var(--amber-lt);color:#633806">29</span></div>
        <div class="tbl-row"><span>Santa Fe</span><span class="pill" style="background:var(--amber-lt);color:#633806">21</span></div>
        <div class="tbl-row"><span>Olavarría</span><span class="pill" style="background:var(--gray-lt);color:#444441">14</span></div>
      </div>
      <div class="card">
        <div class="card-title">Contactos con 2 o más eventos — top recurrentes</div>
        <div class="chart-wrap" style="height:180px"><canvas id="chartMulti"></canvas></div>
        <div class="alert" style="border-color:var(--purple);background:var(--purple-lt);color:var(--purple);margin-top:10px;">
          <strong>108 contactos</strong> asistieron a más de un evento MGN — son el segmento de mayor engagement y candidatos prioritarios para el programa de referidos.
        </div>
      </div>
    </div>
  </div>

  <!-- ══════════ PANEL EVENTOS ══════════ -->
  <div id="panel-eventos" class="panel">
    <div class="three-col">
      <div class="card">
        <div class="card-title">Cena Fin de Año San Nicolás</div>
        <div class="tbl-row"><span>2024</span><span class="pill" style="background:var(--purple-lt);color:var(--purple)">101</span></div>
        <div class="tbl-row"><span>2025</span><span class="pill" style="background:var(--purple-lt);color:var(--purple)">93</span></div>
        <div class="tbl-row"><span>Total</span><span class="pill" style="background:var(--purple-lt);color:var(--purple);font-weight:700">194</span></div>
        <div style="margin-top:8px;font-size:11px;color:var(--t3)">Empresa principal: SIDERSA, Ternium, Acindar</div>
      </div>
      <div class="card">
        <div class="card-title">Evento Cargill</div>
        <div class="tbl-row"><span>Nov 2024</span><span class="pill" style="background:var(--green-lt);color:#085041">45</span></div>
        <div class="tbl-row"><span>Dic 2024</span><span class="pill" style="background:var(--green-lt);color:#085041">58</span></div>
        <div class="tbl-row"><span>Total</span><span class="pill" style="background:var(--green-lt);color:#085041;font-weight:700">103</span></div>
        <div style="margin-top:8px;font-size:11px;color:var(--t3)">Empresa principal: Cargill (Punta Alvear)</div>
      </div>
      <div class="card">
        <div class="card-title">Sustentabilidad San Nicolás</div>
        <div class="tbl-row"><span>2024</span><span class="pill" style="background:var(--amber-lt);color:#633806">78</span></div>
        <div class="tbl-row"><span>100% con respuesta</span><span class="pill" style="background:var(--green-lt);color:#085041">78</span></div>
        <div style="margin-top:8px;font-size:11px;color:var(--t3)">Foco: eficiencia energética e industria</div>
      </div>
      <div class="card">
        <div class="card-title">YPF La Plata</div>
        <div class="tbl-row"><span>Nov 2024</span><span class="pill" style="background:var(--green-lt);color:#085041">67</span></div>
        <div style="margin-top:8px;font-size:11px;color:var(--t3)">Empresa principal: YPF</div>
      </div>
      <div class="card">
        <div class="card-title">Cena Fin de Año Tenaris Siderca</div>
        <div class="tbl-row"><span>Nov 2024</span><span class="pill" style="background:var(--purple-lt);color:var(--purple)">52</span></div>
        <div style="margin-top:8px;font-size:11px;color:var(--t3)">Empresa principal: Tenaris Siderca</div>
      </div>
      <div class="card">
        <div class="card-title">Cena Fin de Año Rosario</div>
        <div class="tbl-row"><span>Nov 2025</span><span class="pill" style="background:var(--green-lt);color:#085041">47</span></div>
        <div style="margin-top:8px;font-size:11px;color:var(--t3)">Empresa principal: Cargill, varias</div>
      </div>
      <div class="card">
        <div class="card-title">Evento Santa Fe</div>
        <div class="tbl-row"><span>Dic 2024</span><span class="pill" style="background:var(--amber-lt);color:#633806">21</span></div>
        <div style="margin-top:8px;font-size:11px;color:var(--t3)">Schneider Electric, Aguas Santafesinas</div>
      </div>
      <div class="card">
        <div class="card-title">Evento Olavarría</div>
        <div class="tbl-row"><span>May 2025</span><span class="pill" style="background:var(--amber-lt);color:#633806">14</span></div>
        <div style="margin-top:8px;font-size:11px;color:var(--t3)">Loma Negra, Cementos Avellaneda</div>
      </div>
      <div class="card">
        <div class="card-title">Listado de Invitados</div>
        <div class="tbl-row"><span>2024–2025</span><span class="pill" style="background:var(--gray-lt);color:#444441">593</span></div>
        <div style="margin-top:8px;font-size:11px;color:var(--t3)">Base regional San Nicolás / Rosario</div>
      </div>
    </div>
  </div>

  <!-- ══════════ PANEL EMPRESAS ══════════ -->
  <div id="panel-empresas" class="panel">
    <div class="two-col">
      <div class="card">
        <div class="card-title">Top empresas por contactos en eventos</div>
        <div class="chart-wrap" style="height:320px"><canvas id="chartEmpresas"></canvas></div>
      </div>
      <div class="card">
        <div class="card-title">Detalle por empresa</div>
        <div class="tbl-row"><span>Cargill</span><span class="pill" style="background:var(--green-lt);color:#085041">80</span></div>
        <div class="tbl-row"><span>YPF</span><span class="pill" style="background:var(--green-lt);color:#085041">66</span></div>
        <div class="tbl-row"><span>Tenaris Siderca</span><span class="pill" style="background:var(--green-lt);color:#085041">49</span></div>
        <div class="tbl-row"><span>SIDERAR / Ternium Siderar</span><span class="pill" style="background:var(--green-lt);color:#085041">48</span></div>
        <div class="tbl-row"><span>Ternium</span><span class="pill" style="background:var(--purple-lt);color:var(--purple)">38</span></div>
        <div class="tbl-row"><span>Acindar</span><span class="pill" style="background:var(--purple-lt);color:var(--purple)">34</span></div>
        <div class="tbl-row"><span>ACINDAR S.A.</span><span class="pill" style="background:var(--purple-lt);color:var(--purple)">24</span></div>
        <div class="tbl-row"><span>CARGILL S.A.C.I.</span><span class="pill" style="background:var(--amber-lt);color:#633806">20</span></div>
        <div class="tbl-row"><span>SIPAR Aceros</span><span class="pill" style="background:var(--amber-lt);color:#633806">12</span></div>
        <div class="tbl-row"><span>Molinos Río de la Plata</span><span class="pill" style="background:var(--amber-lt);color:#633806">8</span></div>
        <div class="tbl-row"><span>SIAT S.A.</span><span class="pill" style="background:var(--amber-lt);color:#633806">8</span></div>
        <div class="tbl-row"><span>Celulosa</span><span class="pill" style="background:var(--gray-lt);color:#444441">8</span></div>
        <div class="alert" style="border-color:var(--amber);background:var(--amber-lt);color:#633806;margin-top:10px;">
          Nota: Cargill y Acindar aparecen con variantes de nombre — se recomienda normalizar en Ropofy al importar.
        </div>
      </div>
    </div>
  </div>

  <!-- ══════════ PANEL CONTACTOS ══════════ -->
  <div id="panel-contactos" class="panel">
    <div class="search-wrap">
      <input type="text" id="searchInput" placeholder="Buscar nombre, apellido, empresa..." oninput="filterTable()">
      <select id="filterEvento" onchange="filterTable()">
        <option value="">Todos los eventos</option>
        <option>Cena Fin de Año San Nicolás</option>
        <option>Evento Fin de Año Cargill</option>
        <option>Sustentabilidad San Nicolás</option>
        <option>Evento Fin de Año YPF La Plata</option>
        <option>Cena Fin de Año Tenaris Siderca</option>
        <option>Cena Fin de Año Rosario</option>
        <option>Evento Fin de Año Santa Fe</option>
        <option>Evento Olavarría</option>
        <option>Listado de Invitados</option>
      </select>
      <select id="filterMulti" onchange="filterTable()">
        <option value="">Todos</option>
        <option value="multi">Solo multi-evento (2+)</option>
      </select>
    </div>
    <div style="font-size:11px;color:var(--t3);margin-bottom:8px" id="tableCount"></div>
    <div style="overflow-x:auto">
      <table class="data-table" id="dataTable">
        <thead>
          <tr>
            <th>Nombre</th><th>Apellido</th><th>Email</th><th>Teléfono</th>
            <th>Empresa</th><th>Cargo</th><th>Ciudad</th><th>Eventos</th>
          </tr>
        </thead>
        <tbody id="tableBody"></tbody>
      </table>
    </div>
    <div class="pagination">
      <button id="btnPrev" onclick="changePage(-1)">← Anterior</button>
      <span id="pageInfo"></span>
      <button id="btnNext" onclick="changePage(1)">Siguiente →</button>
    </div>
  </div>

  <!-- ══════════ PANEL SUSTENTABILIDAD ══════════ -->
  <div id="panel-sustent" class="panel">
    <div class="card" style="margin-bottom:12px">
      <div class="card-title">302 respuestas sobre iniciativas de sustentabilidad y eficiencia energética</div>
      <div style="font-size:12px;color:var(--t2);margin-bottom:12px">Pregunta: ¿Qué iniciativas o soluciones están implementando en su industria para promover la sostenibilidad o mejorar la eficiencia energética?</div>
      <div id="sustentList" style="max-height:500px;overflow-y:auto"></div>
    </div>
  </div>

  <div class="footer">MGN Soluciones Eléctricas · Dashboard de Eventos 2024–2025 · Enlazar.digital</div>
</div>

<script>
function showPanel(id,btn){
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.getElementById('panel-'+id).classList.add('active');
  btn.classList.add('active');
}

const C={green:'#1d9e75',purple:'#3c3489',amber:'#ba7517',red:'#e24b4a',gray:'#888780',teal:'#0f6e56'};
const tick={font:{size:10},color:C.gray};
const grid={color:'#f1efe8'};

new Chart(document.getElementById('chartEventos'),{
  type:'bar',
  data:{
    labels:['Cena SN','Cargill','Sustent. SN','YPF LP','Tenaris','Rosario','Santa Fe','Olavarría'],
    datasets:[{data:[194,103,78,67,52,47,21,14],
      backgroundColor:[C.purple,C.green,C.teal,C.green,C.purple,C.green,C.amber,C.amber],
      borderRadius:4,borderSkipped:false}]
  },
  options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},
    scales:{x:{grid:{display:false},ticks:tick},y:{grid,ticks:tick}}}
});

new Chart(document.getElementById('chartMulti'),{
  type:'doughnut',
  data:{labels:['1 evento','2 eventos','3+ eventos'],
    datasets:[{data:[929,89,19],backgroundColor:[C.gray,C.purple,C.amber],borderWidth:2,borderColor:'#fff'}]},
  options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},cutout:'60%'}
});

new Chart(document.getElementById('chartEmpresas'),{
  type:'bar',
  data:{
    labels:['Cargill','YPF','Tenaris','SIDERAR','Ternium','Acindar','CARGILL SAC','ACINDAR SA','SIPAR','Molinos','SIAT','Celulosa'],
    datasets:[{data:[80,66,49,48,38,34,20,24,12,8,8,8],
      backgroundColor:C.purple,borderRadius:4,borderSkipped:false}]
  },
  options:{responsive:true,maintainAspectRatio:false,indexAxis:'y',
    plugins:{legend:{display:false}},
    scales:{x:{grid,ticks:tick},y:{grid:{display:false},ticks:{...tick,font:{size:10}}}}}
